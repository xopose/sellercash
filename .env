POSTGRES_DB=sellercash
POSTGRES_USER=sellercash
POSTGRES_PASSWORD=sellercash
DATABASE_URL=postgresql+psycopg2://sellercash:sellercash@postgres:5432/sellercash

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=sellercash_docs

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sellercash-docs
MINIO_SECURE=false

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8080

AUTH_ENABLED=true
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=sellercash
KEYCLOAK_FRONTEND_CLIENT_ID=sellercash-web
KEYCLOAK_ISSUER=http://keycloak:8080/realms/sellercash
KEYCLOAK_AUDIENCE=
KEYCLOAK_VERIFY_AUD=false
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
